{
  "expo": {
    "name": "medifleet-app",
    "slug": "medifleet-app",
    "version": "1.0.0",
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/ac9791f2-e3ba-4cc8-ae0c-20d342625903",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Camera needed for expense bill photos and selfie",
        "NSLocationWhenInUseUsageDescription": "GPS needed for live tracking",
        "NSLocationAlwaysUsageDescription": "GPS needed for background tracking",
        "NSPhotoLibraryUsageDescription": "Allow MediFleet to save and attach photos from your library",
        "NSMicrophoneUsageDescription": "Allow MediFleet to record audio notes during a trip"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.medifleetapp.medifleetapp",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "POST_NOTIFICATIONS",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyB8wxgXxQxskgUZG868g_4Qdsezr07i9yA"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow MediFleet to access camera for bill photos",
          "microphonePermission": "Allow MediFleet to record audio notes during a trip"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow MediFleet to use your location for live tracking"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/android-icon-foreground.png",
          "color": "#10b981"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow MediFleet to save and attach photos from your library",
          "savePhotosPermission": "Allow MediFleet to save photos taken during a trip"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "ac9791f2-e3ba-4cc8-ae0c-20d342625903"
      }
    }
  }
}